  "keyFeatures": [
    "SQL query engine powered by Apache DataFusion",
    "Multiple blockchain data extractors (EVM RPC, Firehose, Solana)",
    "High-performance Arrow Flight and JSON Lines query interfaces",
    "Distributed worker architecture for scalable data ingestion",
    "Parquet-based columnar storage optimized for analytics",
    "Real-time streaming query support",
    "Comprehensive admin API for dataset and job management",
    "Built-in telemetry and monitoring with OpenTelemetry"
  ],
  "publicApiSurface": [
    "ampd server - Query server with Arrow Flight (port 1602) and JSON Lines (port 1603)",
    "ampd worker - Distributed worker for data extraction",
    "ampd controller - Admin API server (port 1610)",
    "ampd solo - Development mode with all components",
    "ampctl datasets - Dataset management commands",
    "ampctl jobs - Job control commands",
    "ampctl workers - Worker monitoring commands",
    "ampup - Version manager for ampd installation",
    "Admin API REST endpoints - /datasets, /jobs, /workers, /providers",
    "Arrow Flight DoGet - Execute SQL queries via gRPC",
    "JSON Lines POST /query/jsonl - Execute SQL queries via HTTP"
  ]
